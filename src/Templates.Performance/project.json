{
  "version": "1.0.0-*",
  "compilationOptions": {
    "emitEntryPoint": true
  },
  "content": [ "CSharpClassTemplate.tcs", "CSharpPreparseTemplate.tcs" ],
  "dependencies": {
    "Templates": ""
  },
  "configurations": {
    "release": {
      "compilationOptions": { "define": [ "TRACE" ] },
      "optimize": true
    },
    "debug": { "compilationOptions": { "define": [ "TRACE", "DEBUG" ] } }
  },
  "commands": {
    "Templates.Performance": "run"
  },
  "frameworks": {
    "dnxcore50": {
      "dependencies": {
        "NETStandard.Library": "1.5.0-*",
        "System.Runtime": "4.1.0-*",
        "System.Console": "4.0.0-*",
        "System.Linq.Parallel": "4.0.1-*"
      }
    }
  }
}