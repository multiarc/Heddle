{
  "version": "1.0.0-*",
  "buildOptions": {
    "emitEntryPoint": true,
    "copyToOutput": {
      "include": [ "TestTemplates", "CSharpClassTemplate.tcs", "CSharpPreparseTemplate.tcs" ]
    }
  },
  "dependencies": {
    "Templates": "2.8.*"
  },
  "configurations": {
    "release": {
      "buildOptions": { "define": [ "TRACE" ] },
      "optimize": true
    },
    "debug": { "buildOptions": { "define": [ "TRACE", "DEBUG" ] } }
  },
  "commands": {
    "Templates.Performance": "run"
  },
  "frameworks": {
    "net461": {
    },
    "netcoreapp1.1": {
      "imports": [ "dnxcore50", "netstandard1.6" ],
      "dependencies": {
        "Microsoft.NETCore.App": {
          "type": "platform",
          "version": "1.1.0-*"
        },
        "NETStandard.Library": "1.6.1",
        "System.Runtime": "4.3.0",
        "System.Console": "4.3.0",
        "System.Linq.Parallel": "4.3.0"
      }
    }
  }
}