{
  "version": "1.0.0-*",
  "buildOptions": {
    "emitEntryPoint": true,
    "copyToOutput": {
      "include": [ "TestTemplates", "CSharpClassTemplate.tcs", "CSharpPreparseTemplate.tcs" ]
    }
  },
  "dependencies": {
    "Templates": "2.7.13-rc2"
  },
  "configurations": {
    "release": {
      "buildOptions": { "define": [ "TRACE" ] },
      "optimize": true
    },
    "debug": { "buildOptions": { "define": [ "TRACE", "DEBUG" ] } }
  },
  "commands": {
    "Templates.Performance": "run"
  },
  "frameworks": {
    "net461": {
    },
    "net451": {
    },
    "netcoreapp1.0": {
      "imports": "dnxcore50",
      "dependencies": {
        "Microsoft.NETCore.App": {
          "type": "platform",
          "version": "1.0.0-*"
        },
        "NETStandard.Library": "1.5.0-*",
        "System.Runtime": "4.1.0-*",
        "System.Console": "4.0.0-*",
        "System.Linq.Parallel": "4.0.1-*"
      }
    }
  }
}