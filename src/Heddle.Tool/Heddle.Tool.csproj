<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <AssemblyName>Heddle.Tool</AssemblyName>
    <RootNamespace>Heddle.Tool</RootNamespace>

    <!-- WI12 / roadmap "Codegen CLI distribution": the T4-successor CLI hosts the full dynamic engine and ships like
         the phase 6 LSP server — a normal dotnet tool, per-RID ReadyToRun for fast cold start. -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>heddle</ToolCommandName>
    <PackageId>Heddle.Tool</PackageId>
    <Version>2.0.0$(VersionSuffix)</Version>
    <Description>Heddle template-engine CLI: render a template against a JSON model (a T4-successor codegen tool).</Description>
    <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm64;linux-musl-x64;osx-x64;osx-arm64;any</RuntimeIdentifiers>
    <!-- R2R is opt-in via EnableToolR2R (set by the CI release/publish steps). Keeping the property
         visible at the RID-less outer restore lets the crossgen2 runtime packs for every RuntimeIdentifier
         restore (fixes NETSDK1094 during `dotnet pack`), while ordinary dev/CI builds and beta packs stay
         crossgen-free. 'any' has no RID to crossgen, so it is always excluded. Mirrors Heddle.LanguageServer. -->
    <PublishReadyToRun Condition="'$(EnableToolR2R)' == 'true' AND '$(RuntimeIdentifier)' != 'any'">true</PublishReadyToRun>
    <SelfContained>false</SelfContained>

    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\heddle.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Heddle.Tool.Tests, " />
  </ItemGroup>

  <ItemGroup>
    <!-- The full dynamic engine — precompiled templates are a build-time cache, but the CLI hosts the unrestricted
         runtime so any template (including runtime-loaded and :: dynamic) renders. -->
    <ProjectReference Include="..\Heddle\Heddle.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Directory.Build.props sets PackageReadmeFile=README.md for every project, so the file must be
         packed (else NU5039). Matches Heddle.LanguageServer / Heddle.Language. -->
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
