<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Facade targets modern CoreCLR only: collectible AssemblyLoadContext (D14) requires it. The engine's
         own TFMs (netstandard2.0;net6.0;net8.0;net10.0) are untouched — this narrowing is a property of the new
         package (phase 6 D21). -->
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Version>1.0.0$(VersionSuffix)</Version>
    <Product>Heddle.LanguageServices</Product>
    <Description>Editor language-service facade for the Heddle template engine (completion, diagnostics, hover, go-to-definition).</Description>
    <PackageId>Heddle.LanguageServices</PackageId>
    <IncludeSymbols>true</IncludeSymbols>
    <LangVersion>latest</LangVersion>
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\heddle.snk</AssemblyOriginatorKeyFile>
    <Nullable>disable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Heddle\Heddle.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Heddle.LanguageServices.Tests, " />
    <InternalsVisibleTo Include="Heddle.LanguageServer, " />
  </ItemGroup>

</Project>
