                                            <span class="align-left">Includes @(@((dynamic)model.Values).AddedSugars)@(@((dynamic)model.Units).AddedSugars) </span>
                                            <span class="padding-value"> @(@((dynamic)model.DisplayNames).AddedSugars)</span>
                                            <span class="align-right bold">@(@((dynamic)model.Values).AddedSugarsPercent)%</span>
                                        </div>
                                    </div>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="bold align-left">@(@((dynamic)model.DisplayNames).Protein)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).Protein)@(@((dynamic)model.Units).Protein)</span>
                                    @if(@((dynamic)model.Values).ProteinPercent != null)
                                    {{
                                        <span class="align-right bold">@(@((dynamic)model.Values).ProteinPercent)%</span>
                                    }}
                                </div>
                                <hr style="height: 7px;">
                                <table>
                                    <tr class="nutrition-standard-template-line">
                                        <td>
                                            <span class="align-left">@(@((dynamic)model.DisplayNames).VitaminD) @(@((dynamic)model.Values).VitaminD)@(@((dynamic)model.Units).VitaminD) @(@((dynamic)model.Values).VitaminDPercent)%</span>
                                        </td>
                                        <td>•</td>
                                        <td>
                                            <span class="align-right">@(@((dynamic)model.DisplayNames).Calcium) @(@((dynamic)model.Values).Calcium)@(@((dynamic)model.Units).Calcium) @(@((dynamic)model.Values).CalciumPercent)%</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td colspan="3">
                                            <hr>
                                        </td>
                                    </tr>
                                    <tr class="nutrition-standard-template-line">
                                        <td>
                                            <span class="align-left">@(@((dynamic)model.DisplayNames).Iron) @(@((dynamic)model.Values).Iron)@(@((dynamic)model.Units).Iron) @(@((dynamic)model.Values).IronPercent)%</span>
                                        </td>
                                        <td>•</td>
                                        <td>
                                            <span class="align-right">@(@((dynamic)model.DisplayNames).Potassium) @(@((dynamic)model.Values).Potassium)@(@((dynamic)model.Units).Potassium) @(@((dynamic)model.Values).PotassiumPercent)%</span>
                                        </td>
                                    </tr>
                                </table>

                                @*<div class ="nutrition-standard-template-line align-center">
                                <span class="align-left">@(@((dynamic)model.DisplayNames).VitaminD) @(@((dynamic)model.Values).VitaminD)@(@((dynamic)model.Units).VitaminD) @(@((dynamic)model.Values).VitaminDPercent)%</span>
                                <span class="text-align: center">•</span>
                                <span class="align-right">@(@((dynamic)model.DisplayNames).Calcium) @(@((dynamic)model.Values).Calcium)@(@((dynamic)model.Units).Calcium) @(@((dynamic)model.Values).CalciumPercent)%</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line align-center">
                                <span class="align-left">@(@((dynamic)model.DisplayNames).Iron) @(@((dynamic)model.Values).Iron)@(@((dynamic)model.Units).Iron) @(@((dynamic)model.Values).IronPercent)%</span>
                                <span>•</span>
                                <span class="align-right">@(@((dynamic)model.DisplayNames).Potassium) @(@((dynamic)model.Values).Potassium)@(@((dynamic)model.Units).Potassium) @(@((dynamic)model.Values).PotassiumPercent)%</span>
                                </div>
                                *@
                                <hr style="height: 3px;">
                                <div class="nutrition-standard-template-line">
                                    <span style="font-size:9px;  white-space: normal;">* The % Daily Value (DV) tells you how much a nutrient in
                                        <wbr> a serving of food contributes to a daily diet 2,000 calories
                                        <wbr>a day is used for general nutrition advice.</span>
                                </div>

                            </div>
                            @if(@((dynamic)model.Values).Omegas != null)
                            {{
                                <div class="nutrition-standard-non-supplement-template-omegas">
                                    <div class="nutrition-standard-template-line">
                                        <span>Contains @(@((dynamic)model.Values).Omegas)@(@((dynamic)model.Units).Omegas) omega-3
                                            fatty acids per @(@((dynamic)model.Values).Per)@(@((dynamic)model.Units).Per) serving.
                                            @(@((dynamic)model.Values).EPA)@(@((dynamic)model.Units).EPA) @(@((dynamic)model.DisplayNames).EPA)
                                            @(@((dynamic)model.Values).DHA)@(@((dynamic)model.Units).DHA) @(@((dynamic)model.DisplayNames).DHA)</span>
                                    </div>
                                </div>
                            }}

                        </div>
                    }}
                    @if(@model.TemplateType == root.ProductPage.IngredientsTab.GetNutritionTemplateId("StandardNonSupplementB"))
                    {{
                        <div class="custom-nutrition-template">
                            <div class="nutrition-standard-non-supplement-template">
                                <div class="nutrition-standard-template-line">
                                    <span class="nutrition-standard-template-title non-supplement">Nutrition Facts</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span>@(@((dynamic)model.Values).Servings) @(@((dynamic)model.DisplayNames).Servings) per @(@((dynamic)model.Units).Servings)</span>
                                </div>
                                <div class="nutrition-standard-template-line bold" style="font-size: 15px;">
                                    <span>@(@((dynamic)model.DisplayNames).ServingSize)</span><span class="align-right">@(@((dynamic)model.Values).ServingSize) @(@((dynamic)model.Units).ServingSize)@{(}@@(@((dynamic)model.Values).ServingSizeQuantity)@(@((dynamic)model.Units).ServingSizeQuantity)@{)}@</span>
                                </div>
                                <hr style="height:7px;">
                                <span class="bold" style="font-size:9px; margin-bottom:2px">Amount per serving</span>
                                <div class="nutrition-standard-template-line bold" style="margin-bottom: 5px;">
                                    <span class="bold align-left" style="font-size:30px;">@(@((dynamic)model.DisplayNames).Calories)</span><span class="align-right" style="font-size:33px;">@(@((dynamic)model.Values).Calories)</span>
                                </div>
                                <hr style="height: 3px;">
                                <span class="align-right bold" style="font-size: 11px;">% Daily Value**</span>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="bold align-left">@(@((dynamic)model.DisplayNames).TotalFat)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).TotalFat)@(@((dynamic)model.Units).TotalFat)</span>
                                    <span class="align-right bold">@(@((dynamic)model.Values).TotalFatPercent)%</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <div class="sub-level">
                                        <span class="align-left">@(@((dynamic)model.DisplayNames).SaturatedFat)</span>
                                        <span class="padding-value"> @(@((dynamic)model.Values).SaturatedFat)@(@((dynamic)model.Units).SaturatedFat)</span>
                                        <span class="align-right bold">@(@((dynamic)model.Values).SaturatedFatPercent)%</span>
                                    </div>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <div class="sub-level">
                                        <span class="align-left"><i>@(@((dynamic)model.DisplayNames).TransFat)</i></span>
                                        <span class="padding-value"> @(@((dynamic)model.Values).TransFat)@(@((dynamic)model.Units).TransFat)</span>
                                    </div>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="bold align-left">@(@((dynamic)model.DisplayNames).Cholesterol)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).Cholesterol)@(@((dynamic)model.Units).Cholesterol)</span>
                                    <span class="align-right bold">@(@((dynamic)model.Values).CholesterolPercent)%</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="bold align-left">@(@((dynamic)model.DisplayNames).Sodium)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).Sodium)@(@((dynamic)model.Units).Sodium)</span>
                                    <span class="align-right bold">@(@((dynamic)model.Values).SodiumPercent)%</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="bold align-left">@(@((dynamic)model.DisplayNames).Carbohydrate)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).Carbohydrate)@(@((dynamic)model.Units).Carbohydrate)</span>
                                    <span class="align-right bold">@(@((dynamic)model.Values).CarbohydratePercent)%</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <div class="sub-level">
                                        <span class="align-left">@(@((dynamic)model.DisplayNames).DietaryFiber)</span>
                                        <span class="padding-value"> @(@((dynamic)model.Values).DietaryFiber)@(@((dynamic)model.Units).DietaryFiber)</span>
                                        <span class="align-right bold">@(@((dynamic)model.Values).DietaryFiberPercent)%</span>
                                    </div>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <div class="sub-level">
                                        <span class="align-left">@(@((dynamic)model.DisplayNames).TotalSugars)</span>
                                        <span class="padding-value"> @(@((dynamic)model.Values).TotalSugars)@(@((dynamic)model.Units).TotalSugars)</span>
                                    </div>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <div class="sub-level">
                                        <div class="sub-level">
                                            <span class="align-left">Includes @(@((dynamic)model.Values).AddedSugars)@(@((dynamic)model.Units).AddedSugars) </span>
                                            <span class="padding-value"> @(@((dynamic)model.DisplayNames).AddedSugars)</span>
                                            <span class="align-right bold">@(@((dynamic)model.Values).AddedSugarsPercent)%</span>
                                        </div>
                                    </div>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="bold align-left">@(@((dynamic)model.DisplayNames).Protein)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).Protein)@(@((dynamic)model.Units).Protein)</span>
                                    <span class="align-right bold">@(@((dynamic)model.Values).ProteinPercent)%</span>
                                </div>
                                <hr style="height: 7px;">
                                <div class="nutrition-standard-template-line">
                                    <span class="align-left">@(@((dynamic)model.DisplayNames).VitaminD)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).VitaminD)@(@((dynamic)model.Units).VitaminD)</span>
                                    <span class="align-right">@(@((dynamic)model.Values).VitaminDPercent)%</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="align-left">@(@((dynamic)model.DisplayNames).Calcium)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).Calcium)@(@((dynamic)model.Units).Calcium)</span>
                                    <span class="align-right">@(@((dynamic)model.Values).CalciumPercent)%</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="align-left">@(@((dynamic)model.DisplayNames).Iron)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).Iron)@(@((dynamic)model.Units).Iron)</span>
                                    <span class="align-right">@(@((dynamic)model.Values).IronPercent)%</span>
                                </div>
                                <hr>
                                <div class="nutrition-standard-template-line">
                                    <span class="align-left">@(@((dynamic)model.DisplayNames).Potassium)</span>
                                    <span class="padding-value"> @(@((dynamic)model.Values).Potassium)@(@((dynamic)model.Units).Potassium)</span>
                                    <span class="align-right">@(@((dynamic)model.Values).PotassiumPercent)%</span>
                                </div>

                                <hr style="height: 3px;">
                                <div class="nutrition-standard-template-line">
                                    <span style="font-size:9px;  white-space: normal;">* The % Daily Value (DV) tells you how much a nutrient in
                                        <wbr> a serving of food contributes to a daily diet 2,000 calories
                                        <wbr>a day is used for general nutrition advice.</span>
                                </div>
                            </div>
                            @if(@((dynamic)model.Values).Omegas != null)
                            {{
                                <div class="nutrition-standard-non-supplement-template-omegas">
                                    <div class="nutrition-standard-template-line">
                                        <span>Contains @(@((dynamic)model.Values).Omegas)@(@((dynamic)model.Units).Omegas) omega-3
                                            fatty acids per @(@((dynamic)model.Values).Per)@(@((dynamic)model.Units).Per) serving.
                                            @(@((dynamic)model.Values).EPA)@(@((dynamic)model.Units).EPA) @(@((dynamic)model.DisplayNames).EPA)
                                            @(@((dynamic)model.Values).DHA)@(@((dynamic)model.Units).DHA) @(@((dynamic)model.DisplayNames).DHA)</span>
                                    </div>
                                </div>
                            }}

                        </div>
                    }}
                    @if(@model.TemplateType == root.ProductPage.IngredientsTab.GetNutritionTemplateId("Horizontal"))
                    {{
                        @non_supplement_horizontal_template()
                    }}
                    @if(@model.TemplateType == root.ProductPage.IngredientsTab.GetNutritionTemplateId("Truncated"))
                    {{
                        @non_supplement_truncated_template()
                    }}
                }}
            }}
        }}

    }}

    <product_details>
    {{
        <div class="tabs-control">
            <ul class="nav">
                @(DescriptionTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            @if(TitleOverride){{
                                <li class="nav-item"><a class="nav-link active" href="#tabs-details" data-toggle="tab">@(TitleOverride)</a></li>
                            }}
                            @ifnot(TitleOverride){{
                                <li class="nav-item"><a class="nav-link active" href="#tabs-details" data-toggle="tab">Details</a></li>
                            }}
                        }}
                    }}
                }}
                @(ReviewsTab){{
                    @if(){{
                        @if(@model.ReviewsCount > 0){{
                            <li class="nav-item"><a class="nav-link" href="#tabs-reviews" data-toggle="tab">Reviews</a></li>
                        }}
                    }}
                }}
                @(IngredientsTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            @if(TitleOverride){{
                                <li class="nav-item"><a class="nav-link" href="#tabs-nutrition" data-toggle="tab">@(TitleOverride)</a></li>
                            }}
                            @ifnot(TitleOverride){{
                                <li class="nav-item"><a class="nav-link" href="#tabs-nutrition" data-toggle="tab">Nutrition & Ingredients</a></li>
                            }}
                        }}
                    }}
                }}
                @(RecipesTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            @if(TitleOverride){{
                                <li class="nav-item"><a class="nav-link" href="#tabs-recipes" data-toggle="tab">@(TitleOverride)</a></li>
                            }}
                            @ifnot(TitleOverride){{
                                <li class="nav-item"><a class="nav-link" href="#tabs-recipes" data-toggle="tab">Recipes</a></li>
                            }}
                        }}
                    }}
                }}
                @(ServingTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            @if(TitleOverride){{
                                <li class="nav-item"><a class="nav-link" href="#tabs-serving" data-toggle="tab">@(TitleOverride)</a></li>
                            }}
                            @ifnot(TitleOverride){{
                                <li class="nav-item"><a class="nav-link" href="#tabs-serving" data-toggle="tab">Serving/Care</a></li>
                            }}
                        }}
                    }}
                }}
                @(ShippingTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            @if(TitleOverride){{
                                <li class="nav-item"><a class="nav-link" href="#tabs-shipping" data-toggle="tab">@(TitleOverride)</a></li>
                            }}
                            @ifnot(TitleOverride){{
                                <li class="nav-item"><a class="nav-link" href="#tabs-shipping" data-toggle="tab">Shipping</a></li>
                            }}
                        }}
                    }}
                }}
            </ul>
            <div class="tab-content">
                @(DescriptionTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            <div class="tab-pane fade show active" id="tabs-details" tabindex="0">
                                @pre_description()
                                @(Content)
                            </div>
                        }}
                    }}
                }}
                @(ReviewsTab):param(Url){{
                    @if(){{
                        @if(@model.ReviewsCount > 0){{
                            <div class="tab-pane fade" id="tabs-reviews" tabindex="0">
                                <p class="product-reviews-overall">
                                    Average Ratings:
                                    @review_rating(AverageRatings)
                                    @(AverageRatings)
                                </p>
                                <button class="reset write-review-link">
                                    Write a Review
                                </button>
                                <hr />
                                @list(Reviews) {{
                                    <div class="product-reviews-item">
                                        <div class="reviews-item-rating">
                                            @review_rating(Rating)
                                        </div>
                                        <div class="reviews-item-info">
                                            <span class="reviews-item-title">"@(Title)"</span>
                                            <span class="reviews-item-author">@(CustomerName) on @date(DateCreated){{g}}</span>
                                            <span class="reviews-item-text"><b>Review:</b> @(Review)</span>
                                        </div>
                                    </div>
                                    <hr />
                                }}
                                @if(@model.ReviewsCount > 3){{
                                    <a class="read-more-reviews" href="/reviews/@(@chained)">
                                        Read more reviews >
                                    </a>
                                }}
                            </div>
                        }}
                    }}
                }}
                @(IngredientsTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            <div class="tab-pane fade" id="tabs-nutrition" tabindex="0">
                                @product_nutrition()
                            </div>
                        }}
                    }}
                }}
                @(RecipesTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            <div class="tab-pane fade" id="tabs-recipes" tabindex="0">
                                @(Content)
                                @if(@model.Recipes.Count > 0){{
                                    <div class="recipes">
                                        @list(Recipes){{
                                            <a class="product-recipe-link" title="@(Name)" href="@(Url)">@(Name)</a>
                                        }}
                                    </div>
                                }}
                            </div>
                        }}
                    }}
                }}
                @(ServingTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            <div class="tab-pane fade" id="tabs-serving" tabindex="0">
                                @(Content)
                            </div>
                        }}
                    }}
                }}
                @(ShippingTab) {{
                    @if(){{
                        @ifnot(Hidden){{
                            <div class="tab-pane fade" id="tabs-shipping" tabindex="0">
                                @(Content)
                            </div>
                        }}
                    }}
                }}
            </div>
        </div>
    }}

    <product_accessories>
    {{
        <div class="product-related-accessories">
            <h2 class="product-accessories-title">Try one of these delicious recipes</h2>
            <div class="accessories-container">
                @list(YoutubeVideos) {{
                    <a class="product-related-link"
                        href="javascript:function(){return false;}"
                        data-video-id="@(VideoId)"
                        data-video-modal="true"
                        data-video-autoplay="true"
                        data-video-autoclose="true"
                        aria-haspopup="dialog">
                        <img src="@(Image)" alt="">
                        @(Text)
                    </a>
                }}
            </div>
        </div>
        @if(@model.Skus.Any()){{
            <div id="sli_pdp_recommender" data-sku="@(@model.Skus.First().Code)"></div>
        }}
    }}

    <product_category_for_facebook>
    {{@(BreadcrumbOrderedItems) {{@if(@model.Any())
        {{@list(@model.Take(model.Count - 1))
            {{@(@model.Label.Replace("'", "\\'")) > }}@(@model.Last().Label.Replace("'", "\\'"))}}}}
    }}

    <generate_facebook_content>
    {{
        content_name: '@(@model.Name.Replace("'", "\\'"))',
        content_category: '@product_category_for_facebook()',
        content_ids: [@(@string.Join(",", model.Skus.Select(x => string.Format("'{0}'", x.Code.Replace("'", "\\'")))))],
        content_type: 'product',
        currency: 'USD'
    }}

    <generate_addToCart_facebook_content>
    {{
        content_name: '@(@model.Name.Replace("'", "\\'"))',
        content_category: '@product_category_for_facebook()',
        content_type: 'product',
        currency: 'USD',
    }}

    <special_meta>
    {{
        @specialmeta() {{
            <link rel="alternate" media="only screen and (max-width: 640px)" href="https://m.@(::AppOptions.PublicHostClean)@getrequestpath()">
            <link rel="canonical" href="https://www.@(::AppOptions.PublicHostClean)@getrequestpath()">
        }}
    }}

    <layout> -> (ProductPage)
    {{
        @if(Image){{
            @socialmeta(){{
                <meta property="og:image" content="https://@(::AppOptions.PublicHost)@(Image)">
                <meta itemprop="image" content="https://@(::AppOptions.PublicHost)@(Image)" />
                <link rel="image_src" href="https://@(::AppOptions.PublicHost)@(Image)" />
            }}
        }}
        <div class="product-main relative">
            @product_breadcrumb()
            <section class="product-intro-container">
                @product_introduction()
            </section>
            <section class="product-details" id="product-details-tabs">
                @product_details()
            </section>
            <div style="clear: both;"></div>
            <section class="product-accessories">
                @product_accessories()
            </section>
        </div>
        <script>
            var productPublicId = "@(ProductPublicId)";
        </script>
        @search_popup_area()
        @script(){{
            <script>
                $(document).ready(function () {
                    if (typeof fbq !== 'undefined') {
                        fbq('track', 'ViewContent', {
                            @generate_facebook_content()
                        });

                        $("body").on("click", "#lnkAddToCart", function (e) {
                            try {
                                var jChecked = $("input[name=sku]:checked");
                                skuCode = jChecked.val();
                                price = jChecked.data('price');
                                fbq('track', 'AddToCart', {
                                    @generate_addToCart_facebook_content()
                                    content_ids: [skuCode],
                                    value: price
                                });
                            }
                            catch(e) {}
                        });
                    }
                });
            </script>

            <script src="//vitalchoice.resultspage.com/recommendations/wrapper.js" type="text/javascript"></script>

            @if(ProductSchema)
            {{
                <script type="application/ld+json">
                    @(ProductSchema)
                </script>
            }}
        }}
        @special_meta()
    }}:: TtlProductPageModel
%@