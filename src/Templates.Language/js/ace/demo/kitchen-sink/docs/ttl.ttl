@using() {{VitalChoice.Infrastructure.Domain.Transfer.TemplateModels.ProductPage}}
@using() {{System.Linq}}
@model() {{dynamic}}

@%

    <search_popup_link>
    {{
        <div>
            <button class="reset link-button open-pacifical-popup" type="button">
                Trace Your Skipjack: Click here and enter your can code to see exactly where, when, and how your Vital Choice Skipjack Tuna was caught & more!
            </button>
        </div>
    }}

    <search_popup_image>
    {{
        <p>
            <button class="reset link-button open-pacifical-popup" type="button">
                <img src="/files/skipjack_pdp_button.jpg" alt="Trace Your Skipjack" />
            </button>
        </p>
    }}

    <pre_description>
    {{
    }}

    <pre_short_description>
    {{
    }}

    <search_popup_area>
    {{
        <style>
            #pacifical-popup {
                position: fixed;
                width: 612px;
                height: 727px;
                left: 0;
                right: 0;
                top: 5%;
                z-index: 100000;

                margin-left: auto;
                margin-right: auto;
                box-shadow: 0 0 60px 0 rgba(33,29,25,.6);
                display: none;
                background-color: #fff;
            }

            #pacifical-popup > .close-icon {
                color: black;
            }
        </style>
        @script(){{
            <script>
                $(document).ready(function () {
                    $(".close-icon, #pacifical-popup").click(function () {
                        $("#pacifical-popup").fadeOut(200);
                        $("#pacifical-popup > iframe").remove();
                    });

                    $(".open-pacifical-popup").click(function() {
                        if (typeof ga !== 'undefined') {
                            ga('send', 'event', 'outbound', 'click', "https://login.pacifical.com/framed/vitalchoice/", {
                                'transport': 'beacon'
                            });
                        }
                        $("#pacifical-popup").append('<iframe src="https://login.pacifical.com/framed/vitalchoice/" height="725" width="610"></iframe>');
                        $("#pacifical-popup").fadeIn(200);
                    });
                });
            </script>
        }}
        <div id="pacifical-popup">
            <button class="reset close-icon"><i class="fa fa-close"></i></button>
        </div>
    }}

    <stars>
    {{
        @if(@model >= 1) {{
            <i class="las la-star"></i>
            @stars(@model - 1.0)
        }}
        @if(@model < 1 && model > 0) {{
            <i class="las la-star-half"></i>
        }}
    }}

    <empty_stars>
    {{
        @if(@model >= 1) {{
            <i class="lar la-star"></i>
            @empty_stars(@model - 1.0)
        }}
    }}

    <review_rating>{{
        <span role="img" aria-label="Rating: @() out of 5 stars">
            @stars()
            @empty_stars(@5-model)
        </span>
    }}

    <product_breadcrumb>
    {{
        <nav class="category-breadcrumb" aria-label="breadcrumbs">
            <ol class="breadcrumb">
                @(BreadcrumbOrderedItems) {{
                    @list(@model.Take(model.Count - 1)) {{
                        <li>
                            <a href="@(Url)" title="@(Label)">@(Label)</a>
                        </li>
                    }}
                    @if(@model.Any())
                    {{
                        <li>
                            <span>@(@model.Last().Label)</span>
                        </li>
                    }}
                }}
            </ol>
        </nav>
    }}

    <product_introduction>
    {{
        <img class="product-intro-image" alt="@(Name)" src="@(Image)" />
        <div class="product-intro-info">
            <div class="product-intro-main">
                <div class="product-intro-headers">
                    @if(SubTitle) {{
                        <h1>@(Name)</h1>
                        <div class="product-sub-heading">
                            @(SubTitle)
                        </div>
                        @if(@model.Skus.Any()){{
                            <div class="product-sub-heading-sku" id="hSelectedCode">
                                #@(@model.Skus.First().Code)
                            </div>
                        }}
                    }}
                    @ifnot(SubTitle) {{
                        <h1>@(Name)</h1>
                        @if(@model.Skus.Any()){{
                            <div class="product-sub-heading-sku" id="hSelectedCode">
                                #@(@model.Skus.First().Code)
                            </div>
                        }}
                    }}
                </div>
            </div>
            <div class="product-intro-sub">
                @(ReviewsTab) {{
                    <div class="product-stars-container">
                        @review_rating(AverageRatings)
                    </div>
                    @if(@model.ReviewsCount > 0){{
                        <a href="#tabs-reviews" id="lnkReviewsTab">
                            Read <strong>@(ReviewsCount)</strong> reviews
                        </a>
                    }}
                    <a class="write-review-link" href="#">
                        Write a Review
                    </a>
                }}
            </div>
            <div class="product-intro-description">
                @pre_short_description()
                @(ShortDescription)
            </div>
            @(DescriptionTab) {{
                @if(){{
                    @ifnot(Hidden){{
                        <a class="product-intro-more" href="#product-detais-tabs" id="lnkDescriptionTab">Read more &gt;</a>
                    }}
                }}
            }}
            <div class="product-icons">
                @list(ProductIcons){{
                    <button class="reset product-icon tooltip-st-h-click" data-tooltip-ignore-title="true" data-tooltip-body="@(Description)">
                        <img src="@(Url)" alt="">
                        <div class="product-icon-text">
                            @(Title)
                        </div>
                    </button>
                }}
            </div>
            <input type="hidden" name="selectedSku" value="@(SelectedSku)" />
            @if(@model.IdCustomerType == 1) {{
                <div class="product-action-bar retail">
                    <fieldset class="product-action-left">
                        @if(SubProductGroupName){{
                            <legend class="action-left-header">@(SubProductGroupName)</legend>
                        }}
                        @ifnot(SubProductGroupName){{
                            <legend class="action-left-header">Number of Portions:</legend>
                        }}
                        @list(Skus) {{
                            <label class="product-portion-line">
                                <input name="sku" type="radio" value="@(Code)" data-in-stock="@(@model.InStock.ToString().ToLower())" data-price="@money(Price)" data-autoship="@(AutoShip)" />
                                <span>@(PortionsCount) - @money(Price)
                                    @if(SalesText) {{
                                        <span class="product-best-value">@(SalesText)</span>
                                    }}
                                    @if(DiscountText) {{
                                        <span class="discount">@(DiscountText)</span>
                                    }}
                                </span>
                            </label>
                        }}
                        @if(@model.Skus.Any()){{
                            <div style="display: none;" class="in-stock">
                                @*<span id="spSelectedPrice" class="product-selected-price">Selected Price @money(@model.Skus.First().Price)</span>*@
                                <button id="lnkAddToCart" class="btn custom-btn-danger no-message" data-style="zoom-in">
                                    ADD TO CART
                                    <span class="ladda-label"></span>
                                </button>
                                <div class="product-autoship-container" style="display: none;">
                                    <button class="reset product-autoship-link" aria-label="Set Up AutoDelivery"></button>
                                    <button class="reset tooltip-v" data-tooltip-title="Learn About AutoDelivery" data-tooltip-body="<strong>What is AutoDelivery?</strong><br>
                                        • Schedule automatic shipments of your favorite Vital Choice products.<br>
                                        • Get free shipping + 10% off every shipment.<br>
                                        • Get reminder emails before each scheduled shipment.<br>
                                        • Cannot be combined with other discounts or offers.<br>
                                        • Not available for Canadian or other international addresses.<br>
                                        • Pause or cancel anytime<br>">
                                        <i class="glyphicon glyphicon-question-sign"></i>
                                    </button>
                                </div>
                            </div>
                        }}
                    </fieldset>
                    <div class="product-action-right">
                        @if(@model.Skus.Any()){{
                            <div style="display: none;" class="out-of-stock">
                                <div class="out-of-stock-image">
                                    Sorry, we are temporarily<br />out of stock
                                </div>
                                <div class="out-of-stock-text">
                                    Due to demand, this product is temporarily out of stock. Sign up for our waitlist and be the first to know when it’s back!
                                </div>

                                <button class="btn custom-btn-danger out-of-stock-button">Notify Me</button>
                            </div>
                            <div style="display: none;" class="in-stock cart-list">
                                <div class="guarantee-icon">
                                    <i class='fa fa-check'></i>
                                </div>
                                <div class="shipping-messaging">
                                    Vital Choice Guarantee: We'll replace your product or refund your money if you're not satisfied.
                                </div>
                                <div class="shipping-seal">
                                    Free shipping<br>on orders over $99
                                </div>
                            </div>
                        }}
                    </div>
                </div>
            }}
            @ifnot(@model.IdCustomerType == 1) {{
                <div class="product-action-bar">
                    <div class="product-action-left">
                        @if(SubProductGroupName){{
                            <span class="action-left-header">@(SubProductGroupName)</span>
                        }}
                        @ifnot(SubProductGroupName){{
                            <span class="action-left-header">Number of Portions:</span>
                        }}
                        @list(Skus) {{
                            <label class="product-portion-line">
                                <input name="sku" type="radio" value="@(Code)" data-in-stock="@(@model.InStock.ToString().ToLower())" data-price="@money(Price)" data-autoship="@(AutoShip)" />
                                @(PortionsCount) - @money(Price)
                                @if(SalesText) {{
                                    <span class="product-best-value">@(SalesText)</span>
                                }}
                            </label>
                        }}
                    </div>
                    <div class="product-action-right">
                        @if(@model.Skus.Any()){{
                            <div style="display: none;" class="in-stock">
                                <span id="spSelectedPrice" class="product-selected-price">Selected Price @money(@model.Skus.First().Price)</span>
                                @if(@model.ShowDiscountMessage == true){{
                                    <span class="wholesale-message-line">15% discount on largest size</span>
                                    <button id="lnkAddToCart" class="ladda-button" data-style="zoom-in">
                                        ADD TO CART
                                        <span class="ladda-label"></span>
                                    </button>
                                }}
                                @ifnot(@model.ShowDiscountMessage == true){{
                                    <button id="lnkAddToCart" class="ladda-button no-message" data-style="zoom-in">
                                        ADD TO CART
                                        <span class="ladda-label"></span>
                                    </button>
                                }}
                                <div class="product-autoship-container" style="display: none;">
                                    <button class="reset product-autoship-link"></button>
                                    <button class="tooltip-v" data-tooltip-title="Learn About Auto-Shipping" data-tooltip-body="<strong>Why choose Auto-Shipping?</strong><br>
                                        • Save <b>10% on your next orders if you sign up today.</b><br>
                                        • You get <u>FREE Shipping &amp; Discounts*</u> in every shipment!<br>
                                        • Easily Pause or Cancel your Auto-Shipments at any time.<br>
                                        • We only charge your credit card when an item ships … we'll alert you by email.<br><br>

                                        <strong>Important Notes:</strong><br>
                                        • Your Cart will be emptied of any existing items if you choose Auto-Ship for this item.<br>
                                        • You <em>cannot</em> add other items to your Cart until you finish your Auto-Ship order.<br>
                                        • After clicking Auto-Ship, you must log in to your account, or create one.<br>
                                        • Choose your desired delivery schedule on the page that appears after you log in.
                                        <br><br>
                                        *Cannot be combined with other offers.">
                                        <i class="glyphicon glyphicon-question-sign"></i>
                                    </button>
                                </div>
                            </div>
                            <div style="display: none;" class="out-of-stock">
                                <a href="#">
                                    <img src="/images/OOS-graphic.png" />
                                </a>
                            </div>
                        }}
                    </div>
                </div>
            }}
            @*
            @list(Skus) {{
            <div class="hide" itemscope itemtype="http://schema.org/Product">
            <span itemprop="name">@(@root.ProductPage.Name) @(@root.ProductPage.SubTitle)</span>
            <meta itemprop="sku" content="@(Code)" />
            <div itemprop="offers" itemscope itemtype="http://schema.org/Offer">
            <meta itemprop="priceCurrency" content="USD" />$
            <span itemprop="price">@(@model.Price.ToString("F"))</span>
            <meta itemprop="itemCondition" itemtype="http://schema.org/OfferItemCondition" content="http://schema.org/NewCondition"/>New
            @if(InStock) {{
            <meta itemprop="availability" content="http://schema.org/InStock"/>in stock
            }}
            @ifnot(InStock){{
            <meta itemprop="availability" content="http://schema.org/OutOfStock"/>out of stock
            }}
            </div>
            </div>
            }}
            *@
        </div>
    }}

    <default_template>
    {{
        <div class="ingredients-nutrition-facts">
            <div class="nutrition-facts-line">
                <span class="facts-static-title">Nutrition Facts</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-nutrition-title">@(NutritionalTitle)</span>
            </div>
            @if(ServingSize){{
                <div class="nutrition-facts-line">
                    <span class="facts-nutrition-line">Serving Size @(ServingSize)</span>
                </div>
            }}
            @if(Servings){{
                <div class="nutrition-facts-line">
                    <span class="facts-nutrition-line">Number of servings: @(Servings)</span>
                </div>
            }}
            <hr />
            <div class="nutrition-facts-line">
                <span class="facts-hint-line">Amount Per Serving</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-subtitle">Calories</span>
                <span class="facts-info-line">@(Calories)</span>
                <span class="facts-info-value">Calories from Fat @(CaloriesFromFat)</span>
            </div>
            <hr />
            <div class="nutrition-facts-line">
                <span class="facts-hint-value">% Daily Value*</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-subtitle">Total Fat</span>
                <span class="facts-info-line">@(TotalFat)</span>
                <span class="facts-info-value">@(TotalFatPercent)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-indent facts-info-line">Saturated Fat @(SaturatedFat)</span>
                <span class="facts-info-value">@(SaturatedFatPercent)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-indent facts-info-line">Trans Fat @(TransFat)</span>
                <span class="facts-info-value">@(TransFatPercent)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-subtitle">Cholesterol</span>
                <span class="facts-info-line">@(Cholesterol)</span>
                <span class="facts-info-value">@(CholesterolPercent)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-subtitle">Sodium</span>
                <span class="facts-info-line">@(Sodium)</span>
                <span class="facts-info-value">@(SodiumPercent)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-subtitle">Total Carbohydrate</span>
                <span class="facts-info-line">@(TotalCarbohydrate)</span>
                <span class="facts-info-value">@(TotalCarbohydratePercent)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-indent facts-info-line">Dietary Fiber @(DietaryFiber)</span>
                <span class="facts-info-value">@(DietaryFiberPercent)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-indent facts-info-line">Sugars @(Sugars)</span>
                <span class="facts-info-value">@(SugarsPercent)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-info-subtitle">Protein</span>
                <span class="facts-info-line">@(Protein)</span>
                <span class="facts-info-value">@(ProteinPercent)</span>
            </div>
            <hr />
            <div class="nutrition-facts-line">
                <span class="facts-info-line">@(AdditionalNotes)</span>
            </div>
            <div class="nutrition-facts-line">
                <span class="facts-bottom-hint">* Percent Daily Values are based on a 2,000 calorie diet. Your daily values may be higher or lower depending on your calorie needs.</span>
            </div>
        </div>

    }}

    <non_supplement_horizontal_template>
    {{
        <div class="custom-nutrition-template">
            <div class="nutrition-horizontal-non-supplement-template">
                <div class="row">
                    <div class="column first-column">
                        <div class="nutrition-horizontal-template-title">
                            <span class="nutrition-horizontal-template-title non-supplement">Nutrition Facts</span>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <span>@(@((dynamic)model.Values).Servings) @(@((dynamic)model.DisplayNames).Servings) per @(@((dynamic)model.Units).Servings)</span>
                        </div>
                        <div class="bold">
                            <div class="nutrition-horizontal-template-line">
                                <span>@(@((dynamic)model.DisplayNames).ServingSize)</span>
                            </div>
                            <div class="nutrition-horizontal-template-line">
                                <span>@(@((dynamic)model.Values).ServingSize) @(@((dynamic)model.Units).ServingSize) @{(}@@(@((dynamic)model.Values).ServingSizeQuantity)@(@((dynamic)model.Units).ServingSizeQuantity)@{)}@</span>
                            </div>
                            <hr>
                        </div>
                    </div>
                    <div class="column content-column">
                        <div class="nutrition-horizontal-template-line header">
                            <span class="non-supplement" style="float:left">Amount/serving</span><span class="non-supplement" style="float:right">% Daily Value*</span>
                        </div>
                        <hr style="height: 3px;">
                        <div class="nutrition-horizontal-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).TotalFat)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).TotalFat)@(@((dynamic)model.Units).TotalFat)</span>
                            <span class="align-right bold">@(@((dynamic)model.Values).TotalFatPercent)%</span>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <div class="sub-level">
                                <span class="align-left">@(@((dynamic)model.DisplayNames).SaturatedFat)</span>
                                <span class="padding-value"> @(@((dynamic)model.Values).SaturatedFat)@(@((dynamic)model.Units).SaturatedFat)</span>
                                <span class="align-right bold">@(@((dynamic)model.Values).SaturatedFatPercent)%</span>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <div class="sub-level">
                                <span class="align-left" style="font-style: italic;">@(@((dynamic)model.DisplayNames).TransFat)</span>
                                <span class="padding-value"> @(@((dynamic)model.Values).TransFat)@(@((dynamic)model.Units).TransFat)</span>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).Cholesterol)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).Cholesterol)@(@((dynamic)model.Units).Cholesterol)</span>
                            <span class="align-right bold">@(@((dynamic)model.Values).CholesterolPercent)%</span>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).Sodium)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).Sodium)@(@((dynamic)model.Units).Sodium)</span>
                            <span class="align-right bold">@(@((dynamic)model.Values).SodiumPercent)%</span>
                        </div>
                        <hr style="height: 4px;">
                    </div>
                    <div class="column content-column">
                        <div class="nutrition-horizontal-template-line header">
                            <span class="non-supplement" style="float:left">Amount/serving</span><span class="non-supplement" style="float:right">% Daily Value*</span>
                        </div>
                        <hr style="height: 3px;">
                        <div class="nutrition-horizontal-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).Carbohydrate)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).Carbohydrate)@(@((dynamic)model.Units).Carbohydrate)</span>
                            <span class="align-right bold">@(@((dynamic)model.Values).CarbohydratePercent)%</span>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <div class="sub-level">
                                <span class="align-left">@(@((dynamic)model.DisplayNames).DietaryFiber)</span>
                                <span class="padding-value"> @(@((dynamic)model.Values).DietaryFiber)@(@((dynamic)model.Units).DietaryFiber)</span>
                                <span class="align-right bold">@(@((dynamic)model.Values).DietaryFiberPercent)%</span>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <div class="sub-level">
                                <span class="align-left">@(@((dynamic)model.DisplayNames).TotalSugars)</span>
                                <span class="padding-value"> @(@((dynamic)model.Values).TotalSugars)@(@((dynamic)model.Units).TotalSugars)</span>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <div class="sub-level">
                                <div class="sub-level">
                                    <span class="align-left">Includes @(@((dynamic)model.Values).AddedSugars)@(@((dynamic)model.Units).AddedSugars) </span>
                                    <span class="padding-value"> @(@((dynamic)model.DisplayNames).AddedSugars)</span>
                                    <span class="align-right bold">@(@((dynamic)model.Values).AddedSugarsPercent)%</span>
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-horizontal-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).Protein)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).Protein)@(@((dynamic)model.Units).Protein)</span>
                            @if(@((dynamic)model.Values).ProteinPercent != null){{
                                <span class="align-right bold">@(@((dynamic)model.Values).ProteinPercent)%</span>
                            }}
                        </div>
                        <hr style="height: 4px;">
                    </div>
                    <div class="column last-column">
                        <span>* The % Daily Value (DV) tells you how much
                            a nutrient in a serving of food contributes to a daily diet 2,000 calories
                            a day is used for general nutrition advice.</span>
                    </div>
                </div>
                <div class="row">
                    <div class="column first-column">
                        <div class="row">
                            <div class="column">
                                <span class="bold align-left" style="font-size: 15px;">Calories</span>
                                <span class="bold align-left">per serving</span>
                            </div>
                            <div class="column">
                                <span class="bold align-right" style="font-size: 28px;">@(@((dynamic)model.Values).Calories)</span>
                            </div>
                        </div>
                    </div>
                    <div class="column bottom-nutritional-info">
                        <span>@(@((dynamic)model.DisplayNames).VitaminD) @(@((dynamic)model.Values).VitaminD)@(@((dynamic)model.Units).VitaminD) @(@((dynamic)model.Values).VitaminDPercent)%</span>
                        <span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).Calcium) @(@((dynamic)model.Values).Calcium)@(@((dynamic)model.Units).Calcium) @(@((dynamic)model.Values).CalciumPercent)%</span>
                        <span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).Iron) @(@((dynamic)model.Values).Iron)@(@((dynamic)model.Units).Iron) @(@((dynamic)model.Values).IronPercent)%</span>
                        <span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).Potassium) @(@((dynamic)model.Values).Potassium)@(@((dynamic)model.Units).Potassium) @(@((dynamic)model.Values).PotassiumPercent)%</span>
                        @*<span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).ThiaminPercent) @(@((dynamic)model.Values).ThiaminPercent)%</span>
                        <span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).RiboflavinPercent) @(@((dynamic)model.Values).RiboflavinPercent)%</span>
                        <span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).NiacinPercent) @(@((dynamic)model.Values).NiacinPercent)%</span> *@
                    </div>
                </div>
            </div>
            @if(@((dynamic)model.Values).Omegas != null)
            {{
                <div class="nutrition-horizontal-non-supplement-template-omegas">
                    <div class="row">
                        <div class="column first-column">
                            <span>&nbsp;</span>
                        </div>
                        <div class="column content-column">
                            <span>Contains @(@((dynamic)model.Values).Omegas)@(@((dynamic)model.Units).Omegas) omega-3
                                fatty acids per @(@((dynamic)model.Values).Per)@(@((dynamic)model.Units).Per) serving.
                                @(@((dynamic)model.Values).EPA)@(@((dynamic)model.Units).EPA) @(@((dynamic)model.DisplayNames).EPA)
                                @(@((dynamic)model.Values).DHA)@(@((dynamic)model.Units).DHA) @(@((dynamic)model.DisplayNames).DHA)</span>
                        </div>
                    </div>
                </div>
            }}
        </div>
    }}

    <non_supplement_truncated_template>
    {{
        <div class="custom-nutrition-template">
            <div class="nutrition-truncated-non-supplement-template">
                <div class="row">
                    <div class="column first-column">
                        <div class="nutrition-truncated-template-title">
                            <span class="nutrition-truncated-template-title non-supplement">Nutrition Facts</span>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <span>@(@((dynamic)model.Values).Servings) @(@((dynamic)model.DisplayNames).Servings) per @(@((dynamic)model.Units).Servings)</span>
                        </div>
                        <div class="bold">
                            <div class="nutrition-truncated-template-line">
                                <span>@(@((dynamic)model.DisplayNames).ServingSize)</span>
                            </div>
                            <div class="nutrition-truncated-template-line">
                                <span>@(@((dynamic)model.Values).ServingSize) @{(}@@(@((dynamic)model.Values).ServingSizeQuantity)@(@((dynamic)model.Units).ServingSizeQuantity)@{)}@</span>
                            </div>
                            <hr>
                        </div>
                    </div>
                    <div class="column content-column">
                        <div class="nutrition-truncated-template-line header">
                            <span class="non-supplement" style="float:left">Amount/serving</span><span class="non-supplement" style="float:right">% DV</span>
                        </div>
                        <hr style="height: 3px;">
                        <div class="nutrition-truncated-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).TotalFat)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).TotalFat)@(@((dynamic)model.Units).TotalFat)</span>
                            <span class="align-right bold">@(@((dynamic)model.Values).TotalFatPercent)%</span>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <div class="sub-level">
                                <span class="align-left">@(@((dynamic)model.DisplayNames).SaturatedFat)</span>
                                <span class="padding-value"> @(@((dynamic)model.Values).SaturatedFat)@(@((dynamic)model.Units).SaturatedFat)</span>
                                <span class="align-right bold">@(@((dynamic)model.Values).SaturatedFatPercent)%</span>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <div class="sub-level">
                                <span class="align-left" style="font-style: italic;">@(@((dynamic)model.DisplayNames).TransFat)</span>
                                <span class="padding-value"> @(@((dynamic)model.Values).TransFat)@(@((dynamic)model.Units).TransFat)</span>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).Cholesterol)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).Cholesterol)@(@((dynamic)model.Units).Cholesterol)</span>
                            <span class="align-right bold">@(@((dynamic)model.Values).CholesterolPercent)%</span>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).Sodium)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).Sodium)@(@((dynamic)model.Units).Sodium)</span>
                            <span class="align-right bold">@(@((dynamic)model.Values).SodiumPercent)%</span>
                        </div>
                        <hr style="height: 4px;">
                    </div>
                    <div class="column content-column">
                        <div class="nutrition-truncated-template-line header">
                            <span class="non-supplement" style="float:left">Amount/serving</span><span class="non-supplement" style="float:right">% DV</span>
                        </div>
                        <hr style="height: 3px;">
                        <div class="nutrition-truncated-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).Carbohydrate)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).Carbohydrate)@(@((dynamic)model.Units).Carbohydrate)</span>
                            <span class="align-right bold">@(@((dynamic)model.Values).CarbohydratePercent)%</span>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <div class="sub-level">
                                <span class="align-left">@(@((dynamic)model.DisplayNames).DietaryFiber)</span>
                                <span class="padding-value"> @(@((dynamic)model.Values).DietaryFiber)@(@((dynamic)model.Units).DietaryFiber)</span>
                                <span class="align-right bold">@(@((dynamic)model.Values).DietaryFiberPercent)%</span>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <div class="sub-level">
                                <span class="align-left">@(@((dynamic)model.DisplayNames).TotalSugars)</span>
                                <span class="padding-value"> @(@((dynamic)model.Values).TotalSugars)@(@((dynamic)model.Units).TotalSugars)</span>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <div class="sub-level">
                                <div class="sub-level">
                                    <span class="align-left">Incl. @(@((dynamic)model.Values).AddedSugars)@(@((dynamic)model.Units).AddedSugars) </span>
                                    <span class="padding-value"> @(@((dynamic)model.DisplayNames).AddedSugars)</span>
                                    <span class="align-right bold">@(@((dynamic)model.Values).AddedSugarsPercent)%</span>
                                </div>
                            </div>
                        </div>
                        <hr>
                        <div class="nutrition-truncated-template-line">
                            <span class="bold align-left">@(@((dynamic)model.DisplayNames).Protein)</span>
                            <span class="padding-value"> @(@((dynamic)model.Values).Protein)@(@((dynamic)model.Units).Protein)</span>
                            @if(@((dynamic)model.Values).ProteinPercent != null){{
                                <span class="align-right bold">@(@((dynamic)model.Values).ProteinPercent)%</span>
                            }}
                        </div>
                        <hr style="height: 4px;">
                    </div>
                </div>
                <div class="row" style="line-height: 9px;">
                    <div class="column first-column">
                        <div class="row">
                            <div class="column" style="width:70%">
                                <span class="bold align-left" style="font-size:11px;">Calories</span>
                                <span class="bold align-left" style="font-size:px;">per serving</span>
                            </div>
                            <div class="column calories-value">
                                <span class="bold align-right">@(@((dynamic)model.Values).Calories)</span>
                            </div>
                        </div>
                    </div>
                    <div class="column bottom-nutritional-info">
                        <span>@(@((dynamic)model.DisplayNames).VitaminDPercent) @(@((dynamic)model.Values).VitaminDPercent)%</span>
                        <span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).CalciumPercent) @(@((dynamic)model.Values).CalciumPercent)%</span>
                        <span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).IronPercent) @(@((dynamic)model.Values).IronPercent)%</span>
                        <span>•</span>
                        <span>@(@((dynamic)model.DisplayNames).PotassiumPercent) @(@((dynamic)model.Values).PotassiumPercent)%</span>
                    </div>
                </div>

            </div>

            @if(@((dynamic)model.Values).Omegas != null)
            {{
                <div class="nutrition-truncated-non-supplement-template-omegas">
                    <div class="row">
                        <div class="column first-column">
                            <span>&nbsp;</span>
                        </div>
                        <div class="column content-column">
                            <span>Contains @(@((dynamic)model.Values).Omegas)@(@((dynamic)model.Units).Omegas) omega-3
                                fatty acids per @(@((dynamic)model.Values).Per)@(@((dynamic)model.Units).Per) serving.
                                @(@((dynamic)model.Values).EPA)@(@((dynamic)model.Units).EPA) @(@((dynamic)model.DisplayNames).EPA);
                                @(@((dynamic)model.Values).DHA)@(@((dynamic)model.Units).DHA) @(@((dynamic)model.DisplayNames).DHA)</span>
                        </div>
                    </div>
                </div>
            }}

        </div>

    }}

    <product_nutrition>
    {{

        @if(NutritionalTitle){{
            <span class="ingredients-section-begin">Ingredients:</span>
            @(Content)
            <hr />
        }}
        @if(@model.NutritionInfo == null){{
            @default_template()
        }}

        @if(@model.NutritionInfo != null){{

            @if(@model.IsSupplement == true){{
                @(NutritionInfo)
                {{
                    @if(@model.TemplateType == root.ProductPage.IngredientsTab.GetNutritionTemplateId("StandardSupplement"))
                    {{
                        <div class="custom-nutrition-template">
                            <div class="nutrition-standard-supplement-template">
                                <div class="nutrition-standard-template-line">
                                    <span class="nutrition-standard-template-title">Supplement Facts</span>
                                </div>
                                <div class="nutrition-standard-template-line">

                                    <span class="bold">@(@((dynamic)model.DisplayNames).ServingSize)@{:}@ @(@((dynamic)model.Values).ServingSize) @(@((dynamic)model.Units).ServingSize)</span>
                                </div>
                                <div class="nutrition-standard-template-line">
                                    <span class="bold">@(@((dynamic)model.Values).Servings)</span><span> Servings per container</span>
                                </div>
                                <table class="label-table">
                                    <thead>
                                        <tr><th class="bold-bottom-border" colspan="4" style=" padding: 0; ">
                                            <hr>
                                            <span class="bold" style="float:left;">Amount per serving</span><span class="bold" style="float: right">% Daily Value**       </span>
                                        </th></tr>
                                    </thead>
                                    <tr>
                                        <td class="bold"><span>@(@((dynamic)model.DisplayNames).Calories)</span></td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column bold value-cell" style="font-size:13px"><span>@(@((dynamic)model.Values).Calories)</span></td>
                                        <td class="empty-cell cell-column"></td>
                                    </tr>
                                    <tr>
                                        <td><span>@(@((dynamic)model.DisplayNames).TotalFat)</span></td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).TotalFat)@(@((dynamic)model.Units).TotalFat)</span></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).TotalFatPercent)%</span></td>
                                    </tr>
                                    <tr>
                                        <td class="cell-first-column value-cell">@(@((dynamic)model.DisplayNames).SaturatedFat)</td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column value-cell"><span></span>@(@((dynamic)model.Values).SaturatedFat.ToString().TrimStart('0'))@(@((dynamic)model.Units).SaturatedFat)</td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).SaturatedFatPercent)%</span></td>
                                    </tr>
                                    <tr>
                                        <td>@(@((dynamic)model.DisplayNames).Cholesterol)</td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).Cholesterol)@(@((dynamic)model.Units).Cholesterol)</span></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).CholesterolPercent)%</span></td>
                                    </tr>
                                    <tr>
                                        <td class="bold bold-bottom-border">@(@((dynamic)model.DisplayNames).VitaminD)</td>
                                        <td class="cell-column bold value-cell bold-bottom-border" colspan="2"><span>@(@((dynamic)model.Values).VitaminD)@(@((dynamic)model.Units).VitaminD) @{(}@@(@((dynamic)model.Values).VitaminD*40)IU)</span></td>
                                        <td class="cell-column value-cell bold-bottom-border"><span>@(@((dynamic)model.Values).VitaminDPercent)%</span></td>
                                    </tr>
                                    <tr>
                                        <td class="bold" colspan="2">@(@((dynamic)model.DisplayNames).Omega3)</td>
                                        <td class="cell-column bold value-cell"><span>@(@((dynamic)model.Values).Omega3)@(@((dynamic)model.Units).Omega3)</span></td>
                                        <td class="cell-column value-cell"><span>↑</span></td>
                                    </tr>
                                    <tr>
                                        <td class="value-cell">@(@((dynamic)model.DisplayNames).EPA)</td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).EPA)</span><span>@(@((dynamic)model.Units).EPA)</span></td>
                                        <td class="cell-column value-cell"><span>↑</span></td>
                                    </tr>
                                    <tr>
                                        <td class="value-cell">@(@((dynamic)model.DisplayNames).DHA)</td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).DHA)@(@((dynamic)model.Units).DHA)</span></td>
                                        <td class="cell-column value-cell"><span>↑</span></td>
                                    </tr>
                                    <tr>
                                        <td colspan="2"><span class="bold">@(@((dynamic)model.DisplayNames).Curcumin)</span><span>Curcumin Extract</span></td>
                                        <td class="cell-column value-cell bold"><span>@(@((dynamic)model.Values).Curcumin)@(@((dynamic)model.Units).Curcumin)</span></td>
                                        <td class="cell-column value-cell"><span>↑</span></td>
                                    </tr>
                                    <tr>
                                        <td class="bold-bottom-border" colspan="2"><span class="bold ">@(@((dynamic)model.DisplayNames).FishOil)</span><span style="font-size:7px"> (sockeye salmon & pollock)</span></td>
                                        <td class="cell-column value-cell bold-bottom-border"><span>@(@((dynamic)model.Values).FishOil)@(@((dynamic)model.Units).FishOil)</span></td>
                                        <td class="cell-column value-cell bold-bottom-border"><span>↑</span></td>
                                    </tr>
                                </table>
                                <span>**Percent daily Values are based on 2000 calorie diet</span>
                                <span>↑ Daily Value not established</span>
                            </div>
                        </div>
                    }}
                    @if(@model.TemplateType == root.ProductPage.IngredientsTab.GetNutritionTemplateId("StandardSupplementB"))
                    {{
                        <div class="custom-nutrition-template">
                            <div class="nutrition-standard-supplement-template">
                                <div class="nutrition-standard-template-line">
                                    <span class="nutrition-standard-template-title">Supplement Facts</span>
                                </div>
                                <div class="nutrition-standard-template-line">

                                    <span class="bold">@(@((dynamic)model.DisplayNames).ServingSize)@{:}@ @(@((dynamic)model.Values).ServingSize) @(@((dynamic)model.Units).ServingSize)</span>
                                </div>
                                <div class="nutrition-standard-template-line">
                                    <span class="bold">@(@((dynamic)model.Values).Servings)</span><span> Servings per container</span>
                                </div>
                                <table class="label-table">
                                    <thead>
                                        <tr><th class="bold-bottom-border" colspan="4" style=" padding: 0; ">
                                            <hr>
                                            <span class="bold" style="float:left;">Amount per serving</span><span class="bold" style="float: right">% Daily Value**       </span>
                                        </th></tr>
                                    </thead>
                                    <tr>
                                        <td class="bold"><span>@(@((dynamic)model.DisplayNames).Calories)</span></td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column bold value-cell" style="font-size:13px"><span>@(@((dynamic)model.Values).Calories)</span></td>
                                        <td class="empty-cell cell-column"></td>
                                    </tr>
                                    <tr>
                                        <td><span>@(@((dynamic)model.DisplayNames).TotalFat)</span></td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).TotalFat)@(@((dynamic)model.Units).TotalFat)</span></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).TotalFatPercent)%</span></td>
                                    </tr>
                                    <tr>
                                        <td class="cell-first-column value-cell">@(@((dynamic)model.DisplayNames).SaturatedFat)</td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column value-cell"><span></span>@(@((dynamic)model.Values).SaturatedFat.ToString().TrimStart('0'))@(@((dynamic)model.Units).SaturatedFat)</td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).SaturatedFatPercent)%</span></td>
                                    </tr>
                                    <tr>
                                        <td>@(@((dynamic)model.DisplayNames).Cholesterol)</td>
                                        <td class="empty-cell cell-column"></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).Cholesterol)@(@((dynamic)model.Units).Cholesterol)</span></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).CholesterolPercent)%</span></td>
                                    </tr>
                                    <tr>
                                        <td class="bold bold-bottom-border">@(@((dynamic)model.DisplayNames).VitaminD)</td>
                                        <td class="empty-cell cell-column bold-bottom-border"></td>
                                        <td class="cell-column bold value-cell bold-bottom-border"><span>@(@((dynamic)model.Values).VitaminD)@(@((dynamic)model.Units).VitaminD)</span></td>
                                        <td class="cell-column value-cell bold-bottom-border"><span>@(@((dynamic)model.Values).VitaminDPercent)%</span></td>
                                    </tr>
                                    <tr>
                                        <td class="bold" colspan="2">@(@((dynamic)model.DisplayNames).FishOil)</td>
                                        <td class="cell-column bold value-cell"><span>@(@((dynamic)model.Values).FishOil)@(@((dynamic)model.Units).FishOil)</span></td>
                                        <td class="cell-column value-cell"><span>↑</span></td>
                                    </tr>
                                    <tr>
                                        <td class="bold" colspan="2">@(@((dynamic)model.DisplayNames).Omega3)</td>
                                        <td class="cell-column bold value-cell"><span>@(@((dynamic)model.Values).Omega3)@(@((dynamic)model.Units).Omega3)</span></td>
                                        <td class="cell-column value-cell"><span>↑</span></td>
                                    </tr>
                                    <tr>
                                        <td class="value-cell">@(@((dynamic)model.DisplayNames).EPA)</td>
                                        <td class="cell-column"><span>(Eicosapentaenoic)</span></td>
                                        <td class="cell-column value-cell"><span>@(@((dynamic)model.Values).EPA)</span><span>@(@((dynamic)model.Units).EPA)</span></td>
                                        <td class="cell-column value-cell"><span>↑</span></td>
                                    </tr>
                                    <tr>
                                        <td class="value-cell bold-bottom-border">@(@((dynamic)model.DisplayNames).DHA)</td>
                                        <td class="cell-column bold-bottom-border"><span>(Docosahexaenoic)</span></td>
                                        <td class="cell-column value-cell bold-bottom-border"><span>@(@((dynamic)model.Values).DHA)@(@((dynamic)model.Units).DHA)</span></td>
                                        <td class="cell-column value-cell bold-bottom-border"><span>↑</span></td>
