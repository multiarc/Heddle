            @ifnot(@model.IsSupplement == true){{
                @(NutritionInfo)
                {{
                    @if(@model.TemplateType == root.ProductPage.IngredientsTab.GetNutritionTemplateId("StandardNonSupplement"))
                    {{
                        <div class="custom-nutrition-template">
                            <div class="nutrition-standard-non-supplement-template">
