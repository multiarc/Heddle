{
  "version": "1.4.4-rc1",
  "authors": [ "Aliaksandr Kukrash" ],
  "description": "Template engine language parsers support package, basing on ANTLR4.5 C# target",
  "exclude": [ "bin" ],
  "dependencies": {
    "Antlr4.Runtime": ""
  },
  "scripts": {
    "prebuild": [
      "java -jar \"%project:Directory%\\..\\..\\lib\\antlr-4.5.1-complete.jar\" -Dlanguage=CSharp \"%project:Directory%\\TtlLexer.g4\" \"%project:Directory%\\TtlParser.g4\" -o \"%project:Directory%\\generated\" -lib \"%project:Directory%\\generated\" -package Templates.Language",
      "java -jar \"%project:Directory%\\..\\..\\lib\\antlr-4.5.1-complete.jar\" -Dlanguage=CSharp \"%project:Directory%\\TtlLexerNoWS.g4\" -o \"%project:Directory%\\generated\" -lib \"%project:Directory%\\generated\" -package Templates.Language"
    ],
    "postbuild": "java -jar \"%project:Directory%\\..\\..\\lib\\antlr-4.5.1-complete.jar\" -Dlanguage=JavaScript \"%project:Directory%\\TtlLexer.g4\" \"%project:Directory%\\TtlParser.g4\" -o \"%project:Directory%\\js\" -lib \"%project:Directory%\\js\" "
  },
  "configurations": {
    "release": {
      "compilationOptions": { "define": [ "TRACE" ] },
      "optimize": true
    },
    "debug": { "compilationOptions": { "define": [ "TRACE", "DEBUG" ] } }
  },
  "frameworks": {
    "net451": { },
    "dotnet5.4": {
      "dependencies": {
        "System.Runtime": "4.0.21-*",
        "System.Reflection": "4.1.0-*",
        "System.Text.Encoding": "4.0.11-*",
        "System.Runtime.Extensions": "4.0.11-*",
        "System.Text.RegularExpressions": "4.0.11-*"
      }
    }
  }
}