{
  "version": "1.4.13",
  "authors": [ "Aliaksandr Kukrash" ],
  "description": "Template engine language parsers support package, basing on ANTLR4.5 C# target",
  "buildOptions": {
    "exclude": [ "bin", "obj" ]
  },
  "dependencies": {
    "Antlr4.Runtime": "4.5.3"
  },
  "scripts": {
    "precompile": [
      "java -jar \"%project:Directory%\\..\\..\\lib\\antlr-4.5.3-complete.jar\" -Dlanguage=CSharp \"%project:Directory%\\TtlLexer.g4\" \"%project:Directory%\\TtlParser.g4\" -o \"%project:Directory%\\generated\" -lib \"%project:Directory%\\generated\" -package Templates.Language",
      "java -jar \"%project:Directory%\\..\\..\\lib\\antlr-4.5.3-complete.jar\" -Dlanguage=CSharp \"%project:Directory%\\TtlLexerNoWS.g4\" -o \"%project:Directory%\\generated\" -lib \"%project:Directory%\\generated\" -package Templates.Language"
    ],
    "postcompile": "java -jar \"%project:Directory%\\..\\..\\lib\\antlr-4.5.3-complete.jar\" -Dlanguage=JavaScript \"%project:Directory%\\TtlLexer.g4\" \"%project:Directory%\\TtlParser.g4\" -o \"%project:Directory%\\js\" -lib \"%project:Directory%\\js\" "
  },
  "configurations": {
    "release": {
      "buildOptions": { "define": [ "TRACE" ] },
      "optimize": true
    },
    "debug": {
      "buildOptions": {
        "define": [ "TRACE", "DEBUG" ]
      }
    }
  },
  "frameworks": {
    "net451": {
      "frameworkAssemblies": {
        "System.Runtime": {
          "type": "build"
        }
      }
    },
    "net461": {
      "frameworkAssemblies": {
        "System.Runtime": {
          "type": "build"
        }
      }
    },
    "netstandard1.6": {
      "imports": [
        "portable-net452+win81"
      ],
      "dependencies": {
        "System.Runtime": "4.1.0-*",
        "System.Reflection": "4.1.0-*",
        "System.Text.Encoding": "4.0.11-*",
        "System.Runtime.Extensions": "4.1.0-*",
        "System.Text.RegularExpressions": "4.1.0"
      }
    }
  }
}