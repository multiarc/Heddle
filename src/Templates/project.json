{
  "version": "2.7.13",
  "authors": [ "Aliaksandr Kukrash" ],
  "description": "Robust template engine with C# expressions (Roslyn) support, text template inheritance and override support",
  "packOptions": {
    "files": {
      "includeFiles": [ "LanguageTemplates\\CSharpClassTemplate.tcs", "LanguageTemplates\\CSharpPreparseTemplate.tcs" ]
    }
  },
  "buildOptions": {
    "allowUnsafe": true,
    "exclude": [ "bin", "obj" ]
  },
  "dependencies": {
    "Templates.Language": "1.4.13",
    "Antlr4.Runtime": "4.5.3",
    "Microsoft.Extensions.PlatformAbstractions": "1.0.0",
    "Microsoft.CodeAnalysis.CSharp": "1.3.0",
    "Microsoft.Extensions.DependencyModel": "1.0.0",
    "Microsoft.Extensions.Configuration": "1.0.0",
    "Microsoft.AspNetCore.Hosting.Abstractions": "1.0.0"
  },
  "configurations": {
    "release": {
      "buildOptions": {
        "define": [ "TRACE" ]
      },
      "optimize": true
    },
    "debug": {
      "buildOptions": {
        "define": [ "TRACE", "DEBUG" ]
      }
    }
  },
  "frameworks": {
    "net451": {
      "frameworkAssemblies": {
        "System.Runtime": "",
        "System.Text.Encoding": "",
        "System.Threading.Tasks": "",
        "System.IO": "",
        "System.ComponentModel": "",
        "Microsoft.CSharp": ""
      }
    },
    "net461": {
      "frameworkAssemblies": {
        "System.Runtime": "",
        "System.Text.Encoding": "",
        "System.Threading.Tasks": "",
        "System.IO": "",
        "System.ComponentModel": "",
        "Microsoft.CSharp": ""
      }
    },
    "netstandard1.6": {
      "imports": [
        "portable-net452+win81"
      ],
      "dependencies": {
        "System.Runtime.Loader": "4.0.0",
        "System.IO.Pipes": "4.0.0",
        "System.Runtime.Serialization.Primitives": "4.1.1",
        "Microsoft.CSharp": "4.0.1",
        "System.Collections": "4.0.11",
        "System.Linq": "4.1.0",
        "System.IO": "4.1.0",
        "System.IO.FileSystem.Watcher": "4.0.0",
        "System.Reflection": "4.1.0",
        "System.Reflection.Extensions": "4.0.1",
        "System.Reflection.TypeExtensions": "4.1.0",
        "System.Reflection.Emit": "4.0.1",
        "System.Reflection.Emit.Lightweight": "4.0.1",
        "System.Reflection.Emit.ILGeneration": "4.0.1",
        "System.Globalization": "4.0.11",
        "System.Globalization.Extensions": "4.0.1",
        "System.Text.Encoding.CodePages": "4.0.1",
        "System.Text.Encoding.Extensions": "4.0.11",
        "System.Threading": "4.0.11"
      }
    }
  }
}