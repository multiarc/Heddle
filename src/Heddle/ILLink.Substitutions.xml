<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 9 D4 — the feature-switch substitution. When a trimmed publish sets the
  Heddle.CSharpTierEnabled feature to false (see RuntimeHostConfigurationOption in the WASM host),
  ILLink replaces HeddleFeatures.CSharpTierEnabled with a constant `false`. Every `if (!CSharpTierEnabled)`
  guard then becomes a constant-true early return, so the guarded Roslyn branches (ContextCompilation,
  CSharpContext, AssemblyHelper.GetApplicationReferences, RoslynReferenceProvider) are dead code the linker
  removes together with the whole Microsoft.CodeAnalysis reference graph. Inert unless the switch is trimmed off.
-->
<linker>
  <assembly fullname="Heddle" feature="Heddle.CSharpTierEnabled" featurevalue="false">
    <type fullname="Heddle.Runtime.HeddleFeatures">
      <method signature="System.Boolean get_CSharpTierEnabled()" body="stub" value="false" />
    </type>
  </assembly>
</linker>
