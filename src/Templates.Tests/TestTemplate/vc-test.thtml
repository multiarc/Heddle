@*-------------------------------*@
@*---------Start widgets---------*@
@*-------------------------------*@
<%





@*---------Start Widget 1--------*@
@*-------------------------------*@
@*---------name------------------*@
<seafood_how_to>
{{
@*---------editable--------------*@
	<div>
		Seafood How To Videos
	</div>
@*---------editable--------------*@
}}
@*-------------------------------*@
@*---------End Widget 1----------*@




@*---------Start Widget 2--------*@
@*-------------------------------*@
@*---------name------------------*@
<recipes_by_category>
{{
@*---------editable--------------*@
	<div>
	Recipes By Category
	</div>
@*---------editable--------------*@
}}
@*-------------------------------*@
@*---------End Widget 2----------*@




@*---------Start Widget 3--------*@
@*-------------------------------*@
@*---------name------------------*@
<chef_videos>
{{
@*---------editable--------------*@
	<div>
		Chef Videos
	</div>
@*---------editable--------------*@	
}}
@*-------------------------------*@
@*---------End Widget 3----------*@




@*-------------------------------*@
@*---------End widgets-----------*@
@*-------------------------------*@




@*/////////////////////////////////////////////////////*@




@*-------------------------------*@
@*---------Start columns---------*@
@*-------------------------------*@




@*---------Start left column-----*@
@*-------------------------------*@
<left>
{{
@*---------editable--------------*@
	<div style="float:left;">
		@out()
	</div>
@*---------editable--------------*@	
}}
@*-------------------------------*@
@*---------End left column-------*@




@*---------Start center column---*@
@*-------------------------------*@
<center>
{{
@*---------editable--------------*@
	<div style="float:left;">
		@out()
	</div>
@*---------editable--------------*@	
}}
@*-------------------------------*@
@*---------End center column-----*@




@*---------Start right-----------*@
@*-------------------------------*@
<right>
{{
@*---------editable--------------*@
	<div style="float:right;">
		@out()
	</div>
@*---------editable--------------*@	
}}
@*-------------------------------*@
@*---------End right column------*@




@*-------------------------------*@
@*----------End columns----------*@
@*-------------------------------*@




@*/////////////////////////////////////////////////////*@




@*-------------------------------*@
@*---------Start Layout----------*@
@*-------------------------------*@
<layout>
{{
    <div style="width:1000px; margin:auto auto;">
        @out()
    </div>
}}
<default>
{{
@*---------editable--------------*@
	@layout() {{
		@left()
		{{
			@chef_videos()
			@recipes_by_category()
		}}
		@center()
		{{
			This is master body
		}}
		@right()
		{{
			@seafood_how_to()
		}}
	}}
@*---------editable--------------*@
}}
%>
@*-------------------------------*@
@*---------End Layout------------*@
@*-------------------------------*@
@*----Output top misc----*@
<div style="width:1000px; margin:auto auto;"><img src="http://www.vitalchoice.com/shop/pc/catalog/kitchen_portal/in-the-kitchen-header-4-24-14a.png" width="955" height="90"></div>
<%
	<center:center>
	{{
		This is individual body
	}}
	<left:left>
	{{
		@left()
		Addition to the left
	}}
%>
@default()