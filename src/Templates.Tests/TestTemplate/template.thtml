	<multi_text@*text area with @out()*@>
	{{
		<textarea>@
			out();
		</textarea>
	}}
	<labeled_text:text@*Inheritance test*@>
	{{
		<label>
			@text()@*use base defenition*@
		</label>
	}}
%>
