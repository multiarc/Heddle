upper: @upper(Name)
lower: @(lower(Name))
trim: [@(trim(Padded))]
len: @(len(Name))
contains: @(contains(Name, "ell"))
substr: @(substr(Name, 1, 3))
replace: @(replace(Name, "l", "L"))
abs: @(abs(Negative))
max: @(max(A, B))
round: @(round(Ratio, 2))
format-value: @(format(Ratio, "0.0"))
format-composite: @(format("{0} of {1}", A, B))
