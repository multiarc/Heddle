{# Idiomatic Jinja2 layout for composed-page: renders the section/component
   fragments and the ordered area menus with a for loop, and declares an empty
   content block for extending pages (Phase 5 D5).
   Docs: https://jinja.palletsprojects.com/en/stable/templates/#template-inheritance
         https://jinja.palletsprojects.com/en/stable/templates/#for #}
{{ section.meta }}
{{ section.social }}
{{ comp.assets_styles }}
{{ comp.custom_styles }}
{{ comp.head_scripts }}
{{ comp.body_scripts }}
{% for name in area_names %}
{{ areas[name] }}
{% endfor %}
{{ comp.assets_scripts }}
{{ section.page_scripts }}
{{ section.endpage_scripts }}
{{ comp.body_end_scripts }}
{% block content %}{% endblock %}
