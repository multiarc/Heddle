{# Idiomatic Jinja2 trivial-substitution: plain template, multi-line card,
   bare variable expressions (Phase 5 D5).
   Doc: https://jinja.palletsprojects.com/en/stable/templates/#variables #}
<article>
  <h1>{{ title }}</h1>
  <p class="sku">{{ sku }}</p>
  <p class="price">{{ price }}</p>
  <p class="brand">{{ brand }}</p>
  <p class="cat">{{ category }}</p>
  <p class="avail">{{ availability }}</p>
  <a class="link" href="{{ url }}"><img src="{{ image_url }}"></a>
  <p class="sum">{{ summary }}</p>
  <p class="rating">{{ rating }}</p>
</article>
